  "mailer_templates_magic_link_content": "<div style=\"font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; color: #333; background-color: #FBF7EC; padding: 40px 20px; border-radius: 16px;\"><div style=\"text-align: center; margin-bottom: 30px;\"><img src=\"https://tdt-micro.vercel.app/icon-emb.png\" alt=\"Logo Embryologie\" style=\"width: 100px; height: 100px; border-radius: 50%;\" /></div><h3 style=\"text-align: center; color: #64748b; font-size: 14px; letter-spacing: 2px; text-transform: uppercase;\">Techniques Douces Tissulaires</h3><h2 style=\"text-align: center; color: #1a1a1a; font-size: 24px; font-weight: bold; margin-bottom: 5px; text-transform: uppercase;\">L'Embryologie</h2><h2 style=\"text-align: center; color: #F27D33; font-size: 24px; font-weight: bold; margin-top: 0; text-transform: uppercase;\">Biodynamique</h2><p style=\"text-align: center; font-size: 16px; color: #64748b;\">Voici votre code d'accès sécurisé :</p><div style=\"background-color: #ffffff; padding: 24px; border-radius: 12px; text-align: center; margin: 30px auto; border: 1px solid #e4e4e7; max-width: 300px; box-shadow: 0 4px 6px rgba(0,0,0,0.05);\"><h1 style=\"letter-spacing: 8px; color: #A06C50; margin: 0; font-size: 32px; font-weight: bold;\">{{ .Token }}</h1></div><p style=\"text-align: center; font-size: 14px; color: #64748b;\">Saisissez ce code dans l'application pour valider votre connexion.</p><hr style=\"border: none; border-top: 1px solid #e2e8f0; margin: 30px 0;\" /><p style=\"text-align: center; font-size: 12px; color: #94a3b8;\">par Marc Damoiseaux, Ostéopathe D.O<br>Réalisation FEELPROD</p></div>",
  "mailer_templates_confirmation_content": "<div style=\"font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; color: #333; background-color: #FBF7EC; padding: 40px 20px; border-radius: 16px;\"><div style=\"text-align: center; margin-bottom: 30px;\"><img src=\"https://tdt-micro.vercel.app/icon-emb.png\" alt=\"Logo Embryologie\" style=\"width: 100px; height: 100px; border-radius: 50%;\" /></div><h3 style=\"text-align: center; color: #64748b; font-size: 14px; letter-spacing: 2px; text-transform: uppercase;\">Techniques Douces Tissulaires</h3><h2 style=\"text-align: center; color: #1a1a1a; font-size: 24px; font-weight: bold; margin-bottom: 5px; text-transform: uppercase;\">L'Embryologie</h2><h2 style=\"text-align: center; color: #F27D33; font-size: 24px; font-weight: bold; margin-top: 0; text-transform: uppercase;\">Biodynamique</h2><p style=\"text-align: center; font-size: 16px; color: #64748b;\">Bienvenue. Voici votre code d'accès sécurisé :</p><div style=\"background-color: #ffffff; padding: 24px; border-radius: 12px; text-align: center; margin: 30px auto; border: 1px solid #e4e4e7; max-width: 300px; box-shadow: 0 4px 6px rgba(0,0,0,0.05);\"><h1 style=\"letter-spacing: 8px; color: #A06C50; margin: 0; font-size: 32px; font-weight: bold;\">{{ .Token }}</h1></div><p style=\"text-align: center; font-size: 14px; color: #64748b;\">Saisissez ce code dans l'application pour valider votre inscription.</p><hr style=\"border: none; border-top: 1px solid #e2e8f0; margin: 30px 0;\" /><p style=\"text-align: center; font-size: 12px; color: #94a3b8;\">par Marc Damoiseaux, Ostéopathe D.O<br>Réalisation FEELPROD</p></div>"
